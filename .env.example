# Frontend Environment Configuration

# API Base URL - where your backend server is located
# For local development:
REACT_APP_API_BASE_URL=http://localhost:5000

# For production deployment:
# REACT_APP_API_BASE_URL=https://your-api-domain.com

# For relative URLs (if frontend and backend are on same domain):
# REACT_APP_API_BASE_URL=/api

# Asset Base URL - where files like uploaded invoices are served from
# Defaults to API_BASE_URL if not specified
# REACT_APP_ASSET_BASE_URL=http://localhost:5000
