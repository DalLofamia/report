# Server Configuration
PORT=5000

# Database Configuration
# For local development (SQLite file-based):
# DB_PATH=./projects.db

# For production with absolute path:
# DB_PATH=/var/lib/app/projects.db

# For Docker or cloud deployments (persistent volume):
# DB_PATH=/data/projects.db

# For Windows production:
# DB_PATH=C:\\data\\projects.db

# Default: ./projects.db (relative to server directory)
DB_PATH=./projects.db

# Upload Directory Configuration
# For local development:
# UPLOADS_DIR=./uploads

# For production with absolute path:
# UPLOADS_DIR=/var/lib/app/uploads

# For Docker or cloud deployments (persistent volume):
# UPLOADS_DIR=/data/uploads

# Default: ./uploads (relative to server directory)
UPLOADS_DIR=./uploads

# CORS Configuration (optional)
# CORS_ORIGIN=http://localhost:3000
