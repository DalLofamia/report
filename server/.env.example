# Server Configuration
PORT=5000

# REQUIRED: MySQL Database Configuration
# The app requires MySQL and will fail to start without proper configuration.
# Choose ONE of the following setup methods:

# ============================================================================
# METHOD 1: Connection URL (PlanetScale, ClearDB, Heroku MySQL)
# ============================================================================
# MYSQL_URL=mysql://user:password@host:3306/database
# MYSQL_URL=mysqlssl://user:password@host:3306/database

# ============================================================================
# METHOD 2: Individual Connection Parameters (AWS RDS, Railway, cPanel, etc.)
# ============================================================================
# MYSQL_HOST - hostname or IP address of MySQL server
MYSQL_HOST=localhost

# MYSQL_PORT - MySQL server port (default: 3306)
MYSQL_PORT=3306

# MYSQL_USER - MySQL username
MYSQL_USER=root

# MYSQL_PASSWORD - MySQL password
MYSQL_PASSWORD=password

# MYSQL_DATABASE - database name to use
MYSQL_DATABASE=project_tracker

# MYSQL_SSL - enable SSL for cloud services (optional)
# MYSQL_SSL=true

# ============================================================================
# Upload Directory Configuration
# ============================================================================
# UPLOADS_DIR=./uploads

# ============================================================================
# Quick Start Options
# ============================================================================
# LOCAL: Install MySQL locally or use Docker
#   docker run --name mysql -e MYSQL_ROOT_PASSWORD=password -p 3306:3306 -d mysql:8.0
#   Then create database: CREATE DATABASE project_tracker;

# CLOUD: Use PlanetScale (free tier available)
#   1. Go to https://planetscale.com
#   2. Create account and database
#   3. Copy connection string to MYSQL_URL

# RAILWAY: Add MySQL plugin to Railway project
#   Railway auto-generates MYSQL_HOST, MYSQL_USER, MYSQL_PASSWORD, MYSQL_DATABASE

# TESTING: For development, create local MySQL database:
#   mysql -u root -p
#   CREATE DATABASE project_tracker;
#   GRANT ALL PRIVILEGES ON project_tracker.* TO 'root'@'localhost';
#   FLUSH PRIVILEGES;
