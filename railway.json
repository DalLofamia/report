{
  "name": "project-tracker",
  "runtime": "nodejs",
  "buildCommand": "npm install && npm run build && npm install --prefix server",
  "startCommand": "npm start --prefix server",
  "envVariables": {
    "NODE_ENV": "production",
    "PORT": "5000",
    "DB_PATH": "/data/projects.db",
    "UPLOADS_DIR": "/data/uploads"
  }
}
